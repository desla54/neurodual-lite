{
  "name": "neurodual-lite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "cp node_modules/.bun/wa-sqlite@*/node_modules/wa-sqlite/dist/wa-sqlite-async.wasm apps/web/public/ 2>/dev/null || true",
    "dev": "bun --filter @neurodual/web dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "check": "biome check .",
    "fix": "biome check --write .",
    "typecheck": "tsc --build tsconfig.build.json --force"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@capacitor/cli": "^8.3.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fast-check": "^4.4.0",
    "happy-dom": "^20.3.9",
    "typescript": "^5.9.3",
    "vite": "^7.2.0"
  },
  "patchedDependencies": {
    "@powersync/capacitor@0.4.1": "patches/@powersync%2Fcapacitor@0.4.1.patch"
  }
}
