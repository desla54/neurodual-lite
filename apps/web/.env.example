# Supabase Configuration
# Copy this file to .env.local and fill in your values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PowerSync Configuration (required in production)
# Use HTTPS (a domain) for real deployments.
VITE_POWERSYNC_URL=https://powersync.your-domain.tld

# App URL (for email redirects - reset password, magic link, etc.)
VITE_APP_URL=https://www.neurodual.fr

# RevenueCat Configuration (Mobile only)
VITE_REVENUECAT_ANDROID_KEY=goog_xxxxx
VITE_REVENUECAT_IOS_KEY=appl_xxxxx

# Google OAuth (Native only - for in-app Google Sign-In)
# Get this from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client
VITE_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Sentry Configuration (Error Monitoring)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Optional sample-rate overrides (0..1)
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.01
# VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# PostHog (Analytics + Session Replay)
# VITE_PUBLIC_POSTHOG_KEY=phc_xxx
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# VITE_POSTHOG_DISABLED=0

# Feature Flags
# Set to 'enabled' for premium subscription model (stores distribution)
# Set to 'disabled' for free + donations model (PWA distribution)
VITE_PREMIUM_MODE=disabled
VITE_NATIVE_MODE=disabled

# Donation Link (when PREMIUM_MODE=disabled)
VITE_KOFI_URL=https://ko-fi.com/desla54
